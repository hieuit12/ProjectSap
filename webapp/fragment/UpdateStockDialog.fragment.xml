<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <Dialog id="updateStockDialog" title="{i18n>dialogUpdateStock}">
        <content>
            <f:SimpleForm id="updateStockForm" editable="true" layout="ResponsiveGridLayout">
                <f:content>
                    <Label text="{i18n>materialId}" />
                    <Text text="{formModel>/stockForm/MaterialId}" />
                    
                    <Label text="{i18n>plant}" />
                    <Text text="{formModel>/stockForm/Plant}" />
                    
                    <Label text="{i18n>storageLocation}" />
                    <Text text="{formModel>/stockForm/StorageLocation}" />
                    
                    <Label text="{i18n>quantity}" required="true" />
                    <StepInput value="{formModel>/stockForm/Quantity}" min="0" step="1" />
                </f:content>
            </f:SimpleForm>
        </content>
        <beginButton>
            <Button text="{i18n>btnUpdate}" type="Emphasized" press="onConfirmUpdateStock" />
        </beginButton>
        <endButton>
            <Button text="{i18n>btnCancel}" press="onCancelUpdateStock" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
