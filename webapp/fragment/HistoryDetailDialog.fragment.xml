<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:f="sap.ui.layout.form">
    <Dialog title="{i18n>historyDetailTitle} - {historyDetailModel>/MaterialDocument}" contentWidth="500px">
        <content>
            <f:SimpleForm editable="false" layout="ResponsiveGridLayout" labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="5">
                <f:content>
                    <Label text="{i18n>materialDocumentYear}" />
                    <Text text="{historyDetailModel>/MaterialDocument} / {historyDetailModel>/Year}" />
                    <Label text="{i18n>materialId}" />
                    <ObjectIdentifier title="{historyDetailModel>/MaterialId}" text="{historyDetailModel>/MaterialName}" />
                    <Label text="{i18n>movementText}" />
                    <Text text="{path: 'historyDetailModel>/MovementType', formatter: '.formatter.movementText'} ({historyDetailModel>/MovementType})" />
                    <Label text="{i18n>quantity}" />
                    <ObjectNumber number="{parts: [{path: 'historyDetailModel>/Quantity'}, {path: 'historyDetailModel>/MovementType'}], formatter: '.formatter.formattedHistoryQuantity'}" 
                                  unit="{historyDetailModel>/BaseUnit}"
                                  state="{parts: [{path: 'historyDetailModel>/MovementType'}, {path: 'historyDetailModel>/Quantity'}], formatter: '.formatter.movementState'}" />
                    <Label text="{i18n>plantSloc}" />
                    <Text text="{historyDetailModel>/Plant} / {historyDetailModel>/StorageLocation}" />
                    <Label text="{i18n>postingDate}" />
                    <Text text="{path: 'historyDetailModel>/PostingDate', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'dd/MM/yyyy' }}" />
                    <Label text="{i18n>docDate}" />
                    <Text text="{path: 'historyDetailModel>/DocumentDate', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'dd/MM/yyyy' }}" />
                    <Label text="{i18n>remark}" />
                    <Text text="{historyDetailModel>/Remark}" />
                    <Label text="{i18n>status}" />
                    <ObjectStatus text="{historyDetailModel>/Status}" state="Success" icon="sap-icon://sys-enter-2" />
                </f:content>
            </f:SimpleForm>
        </content>
        <endButton>
            <Button text="{i18n>btnCancel}" press="onCloseHistoryDetail" type="Transparent" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>