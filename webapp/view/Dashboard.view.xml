<mvc:View controllerName="com.sap341.smartwarehouse.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizData="sap.viz.ui5.data"
    xmlns:vizFeeding="sap.viz.ui5.controls.common.feeds">

    <Page id="dashboardPage" showHeader="false" backgroundDesign="Transparent">
        <dependents>
            <!-- Chart Dialog: phóng to hơn -->
            <Dialog id="kpiChartDialog" title="{dashboardChart>/title}"
                    stretchOnPhone="true"
                    contentWidth="680px"
                    contentHeight="460px">
                <content>
                    <viz:VizFrame id="kpiChart"
                                  uiConfig="{applicationSet:'fiori'}"
                                  vizType="{dashboardChart>/vizType}"
                                  height="380px"
                                  width="100%">
                        <viz:dataset>
                            <vizData:FlattenedDataset data="{dashboardChart>/points}">
                                <vizData:dimensions>
                                    <vizData:DimensionDefinition name="Category" value="{dashboardChart>Dim}" />
                                </vizData:dimensions>
                                <vizData:measures>
                                    <vizData:MeasureDefinition name="Value" value="{dashboardChart>Value}" />
                                </vizData:measures>
                            </vizData:FlattenedDataset>
                        </viz:dataset>
                        <viz:feeds>
                            <vizFeeding:FeedItem uid="categoryAxis" type="Dimension" values="Category" />
                            <vizFeeding:FeedItem uid="valueAxis"    type="Measure"   values="Value" />
                        </viz:feeds>
                    </viz:VizFrame>
                </content>
                <beginButton>
                    <Button text="Close" press="onCloseKpiChart" />
                </beginButton>
            </Dialog>
        </dependents>

        <content>
            <VBox class="sapUiMediumMargin animateFadeIn">
                <VBox class="sapUiSmallMarginBottom">
                    <Title text="{i18n>dashboardInsights}" level="H1" titleStyle="H1" class="sapUiTinyMarginBottom" />
                    <Text text="{i18n>welcomeMessage}" class="sapUiSmallMarginBottom" />
                </VBox>

                <!-- KPI Tiles -->
                <layout:Grid containerQuery="true" defaultSpan="XL3 L3 M6 S12" class="sapUiSmallMarginBottom">
                    <GenericTile header="{i18n>catalogSize}" press="onShowKpiChart">
                        <customData><core:CustomData key="kpi" value="CATALOG_SIZE" /></customData>
                        <tileContent>
                            <TileContent>
                                <content><NumericContent value="{TotalMaterials}" icon="sap-icon://product" /></content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>
                    <GenericTile header="{i18n>itemsInWarehouse}" press="onShowKpiChart">
                        <customData><core:CustomData key="kpi" value="TOTAL_STOCK" /></customData>
                        <tileContent>
                            <TileContent>
                                <content><NumericContent value="{TotalStock}" icon="sap-icon://inventory" /></content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>
                    <GenericTile header="{i18n>criticalItems}" press="onShowKpiChart">
                        <customData><core:CustomData key="kpi" value="CRITICAL_ITEMS" /></customData>
                        <tileContent>
                            <TileContent>
                                <content><NumericContent value="{LowStockCount}" icon="sap-icon://alert" /></content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>
                    <GenericTile header="{i18n>activeSites}" press="onShowKpiChart">
                        <customData><core:CustomData key="kpi" value="ACTIVE_SITES" /></customData>
                        <tileContent>
                            <TileContent>
                                <content><NumericContent value="{TotalPlants}" icon="sap-icon://factory" /></content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>
                </layout:Grid>

                <!-- Quick Actions -->
                <VBox class="glassContainer sapUiContentPadding sapUiSmallMarginBottom">
                    <Title text="{i18n>quickActions}" level="H3" class="sapUiSmallMarginBottom" />
                    <HBox gap="1rem" wrap="Wrap">
                        <Button text="{i18n>btnAddMaterial}" type="Emphasized" icon="sap-icon://add"        press="onNavToMaterialList" />
                        <Button text="{i18n>btnGoodsReceipt}"                  icon="sap-icon://add-product" press="onNavToStockList" />
                        <Button text="{i18n>historyTitle}"                      icon="sap-icon://history"     press="onNavToHistory" />
                    </HBox>
                </VBox>

                <!-- ⚠️ LOW STOCK ALERT TABLE (hiện khi có data) -->
                <Panel id="lowStockPanel" headerText="⚠️ Low Stock Alert — Stock Quantity ≤ 10"
                       visible="{lowStockModel>/hasData}"
                       class="sapUiSmallMarginBottom"
                       expandable="false">
                    <Table id="lowStockTable" items="{lowStockModel>/items}" class="glassContainer">
                        <headerToolbar>
                            <OverflowToolbar style="Clear">
                                <Title text="{lowStockModel>/countText}" level="H4" />
                                <ToolbarSpacer />
                                <Button icon="sap-icon://navigation-right-arrow" type="Transparent" press="onNavToStockList" tooltip="View All Stock" />
                            </OverflowToolbar>
                        </headerToolbar>
                        <columns>
                            <Column width="120px"><Text text="Material ID" /></Column>
                            <Column><Text text="Material Name" /></Column>
                            <Column width="70px"><Text text="Plant" /></Column>
                            <Column width="90px"><Text text="Storage Loc" /></Column>
                            <Column hAlign="End" width="100px"><Text text="Quantity" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem type="Navigation" press="onLowStockItemPress">
                                <cells>
                                    <ObjectStatus text="{lowStockModel>MaterialId}" state="Error" icon="sap-icon://alert" />
                                    <Text text="{lowStockModel>MaterialName}" />
                                    <Text text="{lowStockModel>Plant}" />
                                    <Text text="{lowStockModel>StorageLocation}" />
                                    <ObjectNumber number="{lowStockModel>Quantity}" unit="{lowStockModel>BaseUnit}" state="Error" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>

                <!-- Recent Activity -->
                <Table id="recentActivityTable"
                       items="{path: '/HistorySet', sorter: {path: 'PostingDate', descending: true}, length: 5}"
                       class="glassContainer">
                    <headerToolbar>
                        <OverflowToolbar style="Clear">
                            <Title text="{i18n>recentActivity}" level="H3" />
                            <ToolbarSpacer />
                            <Button icon="sap-icon://full-screen" type="Transparent" press="onNavToHistory" />
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column><Text text="{i18n>materialId}" /></Column>
                        <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>postingDate}" /></Column>
                        <Column hAlign="End"><Text text="{i18n>quantity}" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Navigation" press="onRecentHistoryPress">
                            <cells>
                                <ObjectIdentifier title="{MaterialId}" text="{MaterialName}" />
                                <Text text="{path: 'PostingDate', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'dd/MM/yyyy' }}" />
                                <ObjectNumber number="{parts: [{path: 'Quantity'}, {path: 'MovementType'}], formatter: '.formatter.formattedHistoryQuantity'}" unit="{BaseUnit}" state="Information" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>